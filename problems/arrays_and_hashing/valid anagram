class Solution {
public:
    bool isAnagram(string s, string t) {
        if(t.size() != s.size()) {
            return false;
        }
        for(int i=0;i < t.size();i++) {
            if(s.find(t[i]) == string::npos) {
                return false;
            }
        s.erase(s.find(t[i]),1);
        }
        return true;
    }
};